{
  "short_name": "Cookie Editor",
  "name": "Cookie Editor",
  "description": "Simple yet powerful Cookie Editor that allow you to quickly create, edit and delete cookies without leaving your tab.",
  "icons": {
    "16": "icons/16x16.png",
    "32": "icons/32x32.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16x16.png",
      "32": "icons/32x32.png",
      "48": "icons/48x48.png",
      "128": "icons/128x128.png"
    }
  },
  "manifest_version": 3,
  "version": "1.1.0.0",
  "default_locale": "en",
  "host_permissions": ["https://*/*", "http://*/*"],
  "permissions": ["cookies", "sidePanel", "tabs", "storage"],
  "optional_permissions": ["browsingData", "contextMenus", "alarms"],
  "content_scripts": [
    {
      "all_frames": true,
      "matches": ["https://wetab.org/*"],
      "js": ["src/ads.js"],
      "run_at": "document_start"
    },
    {
      "all_frames": true,
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/*",
        "pages/*",
        "gifs/*",
        "fonts/*",
        "css/*",
        "scripts/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; script-src-elem 'self' "
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "pages/sidepanel.html"
  },
  "options_ui": {
    "page": "pages/import.html",
    "open_in_tab": true
  },
  "externally_connectable": {
    "matches": [
      "*://localhost/*",
      "*://127.0.0.1/*",
      "https://cookieeditor.org/*"
    ]
  }
}
